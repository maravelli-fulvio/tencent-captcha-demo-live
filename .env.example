PORT=3000

# Tencent CAPTCHA credentials
TENCENT_SECRET_ID=replace_with_secret_id
TENCENT_SECRET_KEY=replace_with_secret_key
TENCENT_CAPTCHA_APP_ID=189927023
TENCENT_CAPTCHA_APP_SECRET_KEY=replace_with_real_secret

# Host used by the backend to validate ticket
TENCENT_CAPTCHA_ENDPOINT=captcha.intl.tencentcloudapi.com

# Demo controls
DEMO_MODE=false

# Uma linha JSON por verificação no stdout (Render logs / pipelines externos). Não registra ticket/randstr/IP.
POC_STRUCTURED_LOG=false
